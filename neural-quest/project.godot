; Engine configuration file.
; Neural Quest, a retro pixel-art educational RPG about machine learning.

config_version=5

[application]

config/name="Neural Quest"
config/version="0.2.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3")

[autoload]

ContentDb="*res://autoload/content_db.gd"
GameState="*res://autoload/game_state.gd"
Sfx="*res://autoload/sfx.gd"
Music="*res://autoload/music.gd"
Toasts="*res://autoload/toasts.gd"

[display]

window/size/viewport_width=240
window/size/viewport_height=320
window/size/window_width_override=480
window/size/window_height_override=640
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
