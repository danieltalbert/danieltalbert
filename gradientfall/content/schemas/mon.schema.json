{
  "$id": "mon.schema.json",
  "title": "Gradientfall Monster",
  "type": "object",
  "required": ["id", "name", "regions", "tier", "hearts", "attack", "behavior", "ml_flavor", "description"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^mon_[a-z0-9_]+$" },
    "name": { "type": "string", "minLength": 2, "maxLength": 50 },
    "regions": { "type": "array", "minItems": 1, "maxItems": 10, "items": { "type": "string", "enum": ["datasedge_meadows", "gradient_peaks", "latent_forest", "overfit_swamp", "tensor_desert", "frozen_cache", "backprop_foundry", "convolution_coast", "parameter_city", "corpus_citadel"] } },
    "tier": { "type": "string", "enum": ["fodder", "standard", "elite", "world_boss", "dungeon_boss"] },
    "hearts": { "type": "number", "minimum": 0.5, "maximum": 500 },
    "attack": { "type": "number", "minimum": 0.25, "maximum": 10 },
    "behavior": { "type": "string", "enum": ["melee", "ranged", "ambush", "flying", "swarm", "tank", "caster"] },
    "spawn": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "time_of_day": { "type": "string", "enum": ["any", "day", "night", "dawn_dusk"] },
        "weather": { "type": "string", "enum": ["any", "rain", "storm", "snow", "clear"] }
      }
    },
    "variants": { "type": "array", "maxItems": 3, "items": { "type": "string", "enum": ["golden", "corrupted", "night", "weather"] } },
    "drops": {
      "type": "array", "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["item_id", "chance"],
        "additionalProperties": false,
        "properties": {
          "item_id": { "type": "string", "pattern": "^item_[a-z0-9_]+$" },
          "chance": { "type": "number", "minimum": 0.01, "maximum": 1 }
        }
      }
    },
    "ml_flavor": { "type": "string", "minLength": 10, "maxLength": 200 },
    "description": { "type": "string", "minLength": 20, "maxLength": 400 }
  }
}
