{
  "$id": "item.schema.json",
  "title": "Gradientfall Item",
  "type": "object",
  "required": ["id", "name", "category", "rarity", "value", "description"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^item_[a-z0-9_]+$" },
    "name": { "type": "string", "minLength": 2, "maxLength": 50 },
    "category": { "type": "string", "enum": ["weapon", "armor", "material", "consumable", "key_item", "tool", "furniture", "curio", "flora", "fish"] },
    "rarity": { "type": "string", "enum": ["common", "uncommon", "rare", "epic", "golden"] },
    "value": { "type": "integer", "minimum": 0, "maximum": 100000 },
    "description": { "type": "string", "minLength": 10, "maxLength": 300 },
    "found_in": { "type": "array", "maxItems": 10, "items": { "type": "string", "enum": ["datasedge_meadows", "gradient_peaks", "latent_forest", "overfit_swamp", "tensor_desert", "frozen_cache", "backprop_foundry", "convolution_coast", "parameter_city", "corpus_citadel"] } },
    "craftable": { "type": "boolean" },
    "recipe": {
      "type": "array", "minItems": 1, "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["item_id", "qty"],
        "additionalProperties": false,
        "properties": {
          "item_id": { "type": "string", "pattern": "^item_[a-z0-9_]+$" },
          "qty": { "type": "integer", "minimum": 1, "maximum": 99 }
        }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attack": { "type": "integer", "minimum": 0, "maximum": 200 },
        "defense": { "type": "integer", "minimum": 0, "maximum": 200 },
        "hearts_restored": { "type": "number", "minimum": 0, "maximum": 20 }
      }
    }
  }
}
